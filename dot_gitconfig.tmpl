{{/*
Git SSH signing configuration:
1. Trust keys from ~/.config/git/allowed_signers.
2. Select the signing key at sign time via gpg.ssh.defaultKeyCommand.
3. The selector returns the first key listed in allowed_signers that is
   currently loaded in ssh-agent.

This keeps allowed_signers as the source of truth for both trust and key
priority, and avoids storing a stale user.signingkey in ~/.gitconfig.
*/}}


[user]
	email = szkiba@users.noreply.github.com
	name = Iván SZKIBA

[core]
	quotepath = false
	excludesfile = ~/.config/git/ignore
{{- if lookPath "delta" }}
	pager = delta
{{- end }}

[init]
	defaultBranch = main

[gpg]
	format = ssh

[commit]
	gpgsign = true

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
	defaultKeyCommand = {{ .chezmoi.homeDir }}/.config/git/signing-key-command

{{ if lookPath "delta" -}}
[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true

[merge]
	conflictStyle = zdiff3
{{- end }}
