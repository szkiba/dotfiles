{{/*
Signing key selection for Git SSH signing:
1. Read ssh-agent public keys via `ssh-add -L`.
2. Prefer the first eligible key line containing `tpm` (case-insensitive).
3. Otherwise prefer the first eligible `sk-` key line.
4. Otherwise use the first eligible key line.

Eligible key lines:
- Start with `ssh-`, `ecdsa-`, or `sk-`.
- Exclude certificate lines containing `-cert-`.

Result:
- `user.signingkey` is set to the literal public key line (not a file path).
- If no eligible keys are loaded in ssh-agent, `user.signingkey` is omitted.
*/}}
{{- $signingkey := "" -}}
{{- $agentKeys := output "sh" "-c" "ssh-add -L 2>/dev/null || true" -}}
{{- $agentKeys = trim $agentKeys -}}
{{- if $agentKeys -}}
{{-   $firstKey := "" -}}
{{-   $skKey := "" -}}
{{-   range $line := splitList "\n" $agentKeys -}}
{{-     $line = trim $line -}}
{{-     if and $line (or (hasPrefix "ssh-" $line) (hasPrefix "ecdsa-" $line) (hasPrefix "sk-" $line)) (not (contains "-cert-" $line)) -}}
{{-       if not $firstKey -}}
{{-         $firstKey = $line -}}
{{-       end -}}
{{-       if and (not $skKey) (hasPrefix "sk-" $line) -}}
{{-         $skKey = $line -}}
{{-       end -}}
{{-       if and (not $signingkey) (contains "tpm" (lower $line)) -}}
{{-         $signingkey = $line -}}
{{-       end -}}
{{-     end -}}
{{-   end -}}
{{-   if and (not $signingkey) $skKey -}}
{{-     $signingkey = $skKey -}}
{{-   end -}}
{{-   if and (not $signingkey) $firstKey -}}
{{-     $signingkey = $firstKey -}}
{{-   end -}}
{{- end -}}


[user]
	email = szkiba@users.noreply.github.com
	name = Iván SZKIBA
{{- if $signingkey}}{{print "\n\t" "signingkey = " $signingkey}}{{end}}

[core]
	quotepath = false
	excludesfile = ~/.config/git/ignore
{{- if lookPath "delta" }}
	pager = delta
{{- end }}

[init]
	defaultBranch = main

[gpg]
	format = ssh

[commit]
	gpgsign = true

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

{{ if lookPath "delta" -}}
[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true

[merge]
	conflictStyle = zdiff3
{{- end }}
